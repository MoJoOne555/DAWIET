<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── Inherit main website layout ── -->
  <template id="layout" name="Dawiet LUTs Layout" inherit_id="website.layout">
    <xpath expr="//head" position="inside">
      <link rel="preconnect" href="https://fonts.googleapis.com"/>
      <link href="https://fonts.googleapis.com/css2?family=Anton&amp;family=Outfit:wght@300;400;500;600&amp;family=Space+Mono&amp;display=swap" rel="stylesheet"/>
    </xpath>
  </template>

  <!-- ── Custom navbar logo text ── -->
  <template id="navbar_brand" name="Dawiet Navbar Brand" inherit_id="website.navbar">
    <xpath expr="//a[hasclass('navbar-brand')]" position="replace">
      <a class="navbar-brand" href="/" style="font-family:'Anton',sans-serif; font-size:1.4rem; letter-spacing:0.06em;">
        <span style="color:#f0c040;">Dawiet</span> LUTs
      </a>
    </xpath>
  </template>

</odoo>
